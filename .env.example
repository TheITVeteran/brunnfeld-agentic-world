# ─── LLM Backend ──────────────────────────────────────────────
# Leave OPENROUTER_API_KEY unset to use the Claude Code CLI instead.

# OpenRouter — set this to enable live streaming + cheaper models
OPENROUTER_API_KEY=

# ─── Recommended Setup ─────────────────────────────────────────
# Best value: MiniMax M2.7 — fast, multi-agent focused, cheap
CHARACTER_MODEL=minimax/minimax-m2.7
INTERVIEW_MODEL=minimax/minimax-m2.7
CLAUDE_CONCURRENCY=100
USE_HARNESS=true

# ─── Model Options ─────────────────────────────────────────────
# Free (requires privacy opt-in at openrouter.ai/settings/privacy):
# CHARACTER_MODEL=minimax/minimax-m2.5:free
#
# Paid alternatives:
# CHARACTER_MODEL=minimax/minimax-m2.5          # ~$0.05/tick
# CHARACTER_MODEL=deepseek/deepseek-v3.2        # ~$0.03/tick, strong reasoning
# CHARACTER_MODEL=google/gemini-2.5-flash       # fast, 1M context
# CHARACTER_MODEL=anthropic/claude-haiku-4-5    # ~$0.23/tick
# CHARACTER_MODEL=anthropic/claude-sonnet-4-6   # best quality, ~$1.50/tick

# Per-tier overrides (optional — agents, narrator, interview can use different models)
# OPENROUTER_MODEL_HAIKU=anthropic/claude-haiku-4-5-20251001
# OPENROUTER_MODEL_SONNET=anthropic/claude-sonnet-4-6
# OPENROUTER_MODEL_OPUS=anthropic/claude-opus-4-6

# ─── Local Models ──────────────────────────────────────────────
# LM Studio (default port 1234):
# LOCAL_LLM_BASE_URL=http://localhost:1234/v1
# LOCAL_LLM_MODEL=llama-3.2-3b-instruct

# Ollama:
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=llama3.2

# ─── Server ────────────────────────────────────────────────────
# PORT=3333
